{
	"name": "kbx",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && node scripts/inject-csp-hash.mjs",
		"preview": "vite preview",
		"test": "vitest run",
		"test:watch": "vitest",
