		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.2",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"hash-wasm": "^4.12.0",
		"idb": "^8.0.3",
		"kdbxweb": "^2.1.1"
